rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- 權限輔助函式 ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isViewer() {
      return isAuthenticated();
    }

    function isAdminOrViewerRole() {
      let role = getUserRole();
      return isAuthenticated() && (role == 'admin' || role == 'viewer');
    }

    // --- 集合規則 ---

    match /users/{userId} {
      allow list, get: if isViewer();
      allow write: if isAdmin();
    }

    match /inventory_items/{itemId} {
      allow read: if isViewer();
      allow write: if isAdminOrViewerRole();
    }

    match /inventory_purchases/{purchaseId} {
      allow read: if isViewer();
      allow write: if isAdminOrViewerRole();
    }

    match /inventory_orders/{orderId} {
      allow read: if isViewer();
      allow write: if isAdminOrViewerRole();
    }

    match /inventory_counts/{countId} {
      allow read: if isViewer();
      allow write: if isAdminOrViewerRole();
    }

    match /daily_consumption/{docId} {
      allow read: if isViewer();
      allow write: if isAdminOrViewerRole();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
